        <constraint notnull_strength="1" field="ADDRESS" constraints="5" exp_strength="1" unique_strength="0"/>
        <constraint notnull_strength="1" field="OPERATING_INSTITUTION" constraints="1" exp_strength="0" unique_strength="0"/>
        <constraint notnull_strength="1" field="SECTOR" constraints="5" exp_strength="2" unique_strength="0"/>
