        <constraint notnull_strength="0" field="OTHER_USAGE" constraints="0" exp_strength="0" unique_strength="0"/>
        <constraint notnull_strength="0" field="REMARKS" constraints="0" exp_strength="0" unique_strength="0"/>
        <constraint notnull_strength="0" field="OTHER_SPEC" constraints="0" exp_strength="0" unique_strength="0"/>
      </constraints>
      <constraintExpressions>
        <constraint field="fid" desc="" exp=""/>
        <constraint field="FSN" desc="Only allow to input 5 Digit" exp="regexp_match(to_string(&quot;FSN&quot;), '^[0-9]{5}$')&#xd;&#xa;"/>
        <constraint field="GEOTAGGING_STATUS" desc="" exp=""/>
        <constraint field="BLDG_STATUS" desc="" exp=""/>
        <constraint field="FACILITY_NAME" desc="Capital letters only" exp="regexp_match(&quot;FACILITY_NAME&quot;, '^[^ ][A-Z0-9!@#$%^&amp;*()_+=\`~&#xd;&#xa;&#xd;&#xa;\[\]&#xd;&#xa;&#xd;&#xa;{}|\\-:;&quot;\'&lt;>,.?/ ]*[^ñÑ ]$')"/>
