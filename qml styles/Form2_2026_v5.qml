  <defaults>
    <default applyOnUpdate="0" expression="" field="fid"/>
    <default applyOnUpdate="1" expression="CASE &#xd;&#xa;&#x9;WHEN &quot;ean&quot; IS NOT NULL THEN &#xd;&#xa;&#x9;&#x9;&quot;ean&quot;&#xa;&#x9;ELSE &#xd;&#xa;&#x9;&#x9;substr(aggregate(layer:=concat(left(@layer_name,14), '_ea'),aggregate:='concatenate',expression:=&quot;ea_geocode&quot;,concatenator:=',',filter:=contains($geometry,geometry(@parent))),9,6)&#xa;END" field="ean"/>
    <default applyOnUpdate="1" expression="CASE&#xd;&#xa;    -- Branch 2: Other building types with uplocation changes&#xd;&#xa;    WHEN &quot;bldg_type&quot; NOT IN ('08','09','10','11')&#xd;&#xa;         OR attribute(@parent,'uplocation') &lt;> &quot;uplocation&quot;&#xd;&#xa;         OR attribute(@parent,'bldg_type') &lt;> &quot;bldg_type&quot;&#xd;&#xa;    THEN coalesce(&#xd;&#xa;            substr(&#xd;&#xa;                aggregate(&#xd;&#xa;                    layer := concat(substr(@layer_name, 0, 14), '_bldgpts'),&#xd;&#xa;                    aggregate := 'concatenate',&#xd;&#xa;                    expression := &quot;bsn&quot;,&#xd;&#xa;                    concatenator := ',',&#xd;&#xa;                    filter := contains($geometry, geometry(@parent))&#xd;&#xa;                ),&#xd;&#xa;                1, 5   -- first 5 characters (one BSN)&#xd;&#xa;            ),&#xd;&#xa;            CASE &#xd;&#xa;                WHEN &quot;bsn&quot; = '0' AND &quot;bsn&quot; &lt;> '00000' THEN '70001'&#xd;&#xa;                ELSE coalesce(lpad(to_string(&quot;bsn_3&quot; + 1), 5, '0'), '70001')&#xd;&#xa;            END&#xd;&#xa;         )&#xd;&#xa;&#xd;&#xa;    -- Branch 3: Specific building type overrides&#xd;&#xa;&#x9;WHEN &quot;bldg_type&quot; = '08' THEN&#xd;&#xa;&#x9;&#x9;coalesce(&#xd;&#xa;&#x9;&#x9;&#x9;-- First try: one BSN starting with 6&#xd;&#xa;&#x9;&#x9;&#x9;substr(&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;aggregate(&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;layer := concat(substr(@layer_name, 0, 14), '_bldgpts'),&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;aggregate := 'concatenate',&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;expression := &quot;bsn&quot;,&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;concatenator := ',',&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;filter := contains($geometry, geometry(@parent))&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; AND &quot;bsn&quot; LIKE '6%'&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;),&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;1, 5&#xd;&#xa;&#x9;&#x9;&#x9;),&#xd;&#xa;&#x9;&#x9;&#x9;-- Second try: increment bsn_2 safely&#xd;&#xa;&#x9;&#x9;&#x9;CASE &#xd;&#xa;&#x9;&#x9;&#x9;&#x9;WHEN &quot;bsn_2&quot; IS NOT NULL&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;THEN lpad(to_string(to_int(&quot;bsn_2&quot;) + 1), 5, '0')&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;ELSE NULL&#xd;&#xa;&#x9;&#x9;&#x9;END,&#xd;&#xa;&#x9;&#x9;&#x9;-- Final fallback&#xd;&#xa;&#x9;&#x9;&#x9;'60001'&#xd;&#xa;&#x9;&#x9;)&#xd;&#xa;&#xd;&#xa;&#xd;&#xa;    WHEN &quot;bldg_type&quot; = '09' THEN '55555'&#xd;&#xa;    WHEN &quot;bldg_type&quot; IN ('10','11') THEN '00000'&#xd;&#xa;&#xd;&#xa;    -- Fallback&#xd;&#xa;    ELSE to_string(&quot;bsn&quot;)&#xd;&#xa;END&#xd;&#xa;" field="bsn"/>
    <default applyOnUpdate="0" expression="" field="uplocation"/>
