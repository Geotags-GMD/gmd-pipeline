  <defaults>
    <default expression="" applyOnUpdate="0" field="fid"/>
    <default expression="                COALESCE(&#xd;&#xa;                    NULLIF(&#xd;&#xa;                        AGGREGATE(&#xd;&#xa;                            layer := concat(substr(@layer_name, 0, 14), '_bldgpts'),&#xd;&#xa;                            aggregate := 'concatenate',&#xd;&#xa;                            expression := &quot;map_uuid&quot;,&#xd;&#xa;                            concatenator := ',',&#xd;&#xa;                            filter := contains($geometry, geometry(@parent))&#xd;&#xa;                        ),&#xd;&#xa;                        ''  -- treat empty string as NULL&#xd;&#xa;                    ),&#xd;&#xa;                    uuid('WithoutBraces')  -- fallback if aggregate returns nothing&#xd;&#xa;                &#xd;&#xa;&#xd;&#xa;            -- If map_uuid already exists, just keep it&#xd;&#xa;         ,&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&quot;map_uuid&quot;&#xd;&#xa;)" applyOnUpdate="1" field="map_uuid"/>
    <default expression="coalesce(&#xd;&#xa;    &quot;ea_geocode&quot;|| &quot;bsn&quot;,&#xd;&#xa;        aggregate(&#xd;&#xa;            layer := concat(substr(@layer_name, 0, 14), '_ea'),&#xd;&#xa;            aggregate := 'concatenate',&#xd;&#xa;            expression := &quot;ea_geocode&quot;,&#xd;&#xa;            concatenator := ',',&#xd;&#xa;            filter := contains($geometry, geometry(@parent))&#xd;&#xa;        ) || current_value('bsn')&#xd;&#xa;)&#xd;&#xa;" applyOnUpdate="1" field="bsn_geoid"/>
    <default expression="aggregate(layer:=concat(left(@layer_name,14), '_ea'),aggregate:='concatenate',expression:=&quot;ea_geocode&quot;,concatenator:=',',filter:=contains($geometry,geometry(@parent)))" applyOnUpdate="1" field="ea_geocode"/>
    <default expression="CASE &#xd;&#xa;&#x9;WHEN &quot;ean&quot; IS NOT NULL THEN &#xd;&#xa;&#x9;&#x9;&quot;ean&quot;&#xa;&#x9;ELSE &#xd;&#xa;&#x9;&#x9;substr(aggregate(layer:=concat(left(@layer_name,14), '_ea'),aggregate:='concatenate',expression:=&quot;ea_geocode&quot;,concatenator:=',',filter:=contains($geometry,geometry(@parent))),9,6)&#xa;END" applyOnUpdate="1" field="ean"/>
    <default expression="&#xd;&#xa;CASE&#xd;&#xa;&#xd;&#xa;&#xd;&#xa;    -- Branch 2: Other building types with uplocation changes&#xd;&#xa;    WHEN &quot;bldg_type&quot; NOT IN ('08', '09','10','11')&#xd;&#xa;         OR current_value('uplocation') &lt;> &quot;uplocation&quot;&#xd;&#xa;         OR current_value('bldg_type') &lt;> &quot;bldg_type&quot;&#xd;&#xa;    THEN coalesce(&#xd;&#xa;            aggregate(&#xd;&#xa;                layer := concat(substr(@layer_name, 0, 14), '_bldgpts'),&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;aggregate := 'concatenate',&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;expression := &quot;bsn&quot;,&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;concatenator := ',',&#xd;&#xa;                filter := contains($geometry, geometry(@parent)) &#xd;&#xa;            ),&#xd;&#xa;            CASE &#xd;&#xa;                WHEN &quot;bsn&quot; = '0' AND &quot;bsn&quot; &lt;> '00000' THEN '70001'&#xd;&#xa;                ELSE coalesce(lpad(to_string(&quot;bsn_3&quot;) + 1, 5, '0'), '70001')&#xd;&#xa;            END&#xd;&#xa;         )&#xd;&#xa;&#xd;&#xa;    -- Branch 3: Specific building type overrides&#xd;&#xa;    WHEN &quot;bldg_type&quot; = '08' THEN&#xd;&#xa;&#x9;&#x9;coalesce(&#xd;&#xa;&#x9;&#x9;&#x9;aggregate(&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;layer := concat(substr(@layer_name, 0, 14), '_bldgpts'),&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;aggregate := 'concatenate',&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;expression := &quot;bsn&quot;,&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;concatenator := ',',&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;filter := contains($geometry, geometry(@parent)) &#xd;&#xa;&#x9;&#x9;&#x9;)&#x9;,&#xd;&#xa;----&#xd;&#xa;&#x9;    lpad(to_string(&quot;bsn_2&quot;) + 1, 5, '0'),&#xd;&#xa;    '60001'&#xd;&#xa;&#xd;&#xa;&#xd;&#xa;&#xd;&#xa;&#xd;&#xa;&#xd;&#xa;&#xd;&#xa;&#x9;&#x9;)&#xd;&#xa;    &#xd;&#xa;&#x9;WHEN &quot;bldg_type&quot; = '09' THEN '55555'&#xd;&#xa;    WHEN &quot;bldg_type&quot; IN ('10','11') THEN '00000'&#xd;&#xa;&#x9;&#xd;&#xa;    -- Fallback&#xd;&#xa;    ELSE to_string(&quot;bsn&quot;)&#xd;&#xa;END" applyOnUpdate="1" field="bsn"/>
    <default expression="" applyOnUpdate="0" field="bsn_1"/>
    <default expression="case&#xd;&#xa;&#x9;when &quot;bsn_2&quot; is NULL then&#xd;&#xa;   coalesce(maximum(&#xd;&#xa;            to_int(&quot;BSN&quot;),&#xd;&#xa;            filter := to_int(&quot;BSN&quot;) > 60000 AND to_int(&quot;BSN&quot;) &lt; 70000&#xd;&#xa;        ), 60000)&#xd;&#xa;&#xd;&#xa;else &#xd;&#xa;&#x9;&quot;bsn_2&quot;&#xd;&#xa;end" applyOnUpdate="1" field="bsn_2"/>
    <default expression="CASE&#xd;&#xa;    WHEN &quot;bsn_3&quot; IS NULL THEN&#xd;&#xa;        lpad(&#xd;&#xa;            coalesce(&#xd;&#xa;                maximum(&#xd;&#xa;                    to_int(&quot;BSN&quot;),&#xd;&#xa;                    filter := &quot;BSN&quot; LIKE '7%' AND &quot;BSN&quot; NOT LIKE '9%'&#xd;&#xa;                ),&#xd;&#xa;                70000&#xd;&#xa;            ) , &#xd;&#xa;            5,&#xd;&#xa;            '0'&#xd;&#xa;        )&#xd;&#xa;&#xd;&#xa;    ELSE&#xd;&#xa;        to_string(&quot;bsn_3&quot;)&#xd;&#xa;END&#xd;&#xa;" applyOnUpdate="1" field="bsn_3"/>
